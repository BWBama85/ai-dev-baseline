#!/usr/bin/env bash
# ai-dev-baseline — keep the INSTALLED baseline current.
#
# The baseline installs by symlinking a stable clone (e.g. ~/Code/ai-dev-baseline)
# into ~/.<agent>. Keeping that clone current used to be a remembered ritual:
# `git pull` + maybe re-run `install.sh` if a PR moved an installed path. This
# command replaces that ritual with one idempotent entrypoint.
#
# Usage:
#   baseline update            # fast-forward the install-source clone + self-heal links
#   baseline update --check    # report currency only; make NO changes (for a hook)
#   baseline -h | --help
#
# `update` never touches unsafe state: it fast-forwards ONLY when the install-source
# clone is clean, on its default branch, and merely behind origin. A dirty / detached
# / non-default / ahead / diverged clone is surfaced and left untouched — currency is
# a convenience, never a cause of lost work. After a fast-forward it re-runs the
# idempotent installer ONLY when an installed path actually moved (a symlink stopped
# resolving), preserving the exact agent set + hook preference already installed. It first
# PRUNES orphaned links a rename/removal left behind (ownership-scoped — only a dangling
# symlink pointing into the clone), then LOUDLY verifies every canonical manifest link resolves.
#
# The two-clone dev split: this command operates on the clone the global install
# points INTO (the "install-source"). Run from any other clone it refuses, so a dev
# clone is never mistaken for the install source. The dev clone is kept current by
# `/implement-issue`'s preflight auto-sync (issue #17) instead.
#
# `--check` exit codes (a stable machine contract for a future SessionStart hook,
# issue #25): 0 = current · 10 = behind (update available) · 20 = needs attention
# (dirty|ahead|diverged|detached|not-default) · 30 = error (fetch failed | no
# origin/<default> | not a repo). It fetches, prints one status word to stdout, and
# mutates nothing.

set -uo pipefail

# Resolve our own location through symlinks (this script may be reached via a PATH
# symlink) — then find the repo root above bin/. A relative symlink target is resolved
# against the LINK's own directory (not the caller's CWD), so a relative PATH symlink
# (stow/brew style) doesn't yield an empty REPO. Paths stay logical to match how
# install.sh records its symlink targets; the wrong-clone guard below uses `-ef`
# (same-inode) so a symlinked path spelling never causes a false mismatch.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
  link="$(readlink "$self")"
  case "$link" in
    /*) self="$link" ;;
    *)  self="$(dirname "$self")/$link" ;;
  esac
done
REPO="$(cd "$(dirname "$self")/.." && pwd)"
# Shared shell primitives (adb_default_branch / adb_branch_sync_state) — the ONE home.
# shellcheck source=/dev/null
. "$REPO/scripts/lib/common.sh"

# Print just the top contiguous comment block (the header), stripping the leading
# "# " — stops at the first non-comment line, so internal section comments never leak.
usage() { awk 'NR==1 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"; }

# --- discovery ---------------------------------------------------------------

# Print the repo root the global install points INTO, resolved from whichever agent
# root-doc symlink exists (install.sh links each with an absolute target). The link's
# TARGET need not currently resolve — a dangling root doc (the very path that moved, or
# a failed prior repair) still identifies the clone, and repairing it is the whole point;
# the clone is validated by install.sh + agents/ existing, not by the doc file existing.
# Prints nothing and returns 1 when no installed symlink is found.
adb_install_source() {
  local link target root
  for link in "$HOME/.claude/CLAUDE.md" "$HOME/.codex/AGENTS.md" "$HOME/.gemini/GEMINI.md"; do
    [ -L "$link" ] || continue
    target="$(readlink "$link")"
    case "$target" in /*) ;; *) continue ;; esac   # expect an absolute target
    # agents/<agent>/<DOC> sits three levels below the repo root. Logical `pwd` keeps this
    # the same flavor as the recorded symlink targets so adb_installed_links can prefix-
    # match them; the wrong-clone guard uses `-ef`, so no physical canonicalization is needed.
    root="$(cd "$(dirname "$target")/../.." 2>/dev/null && pwd)" || continue
    if [ -f "$root/install.sh" ] && [ -d "$root/agents" ]; then
      printf '%s\n' "$root"; return 0
    fi
  done
  return 1
}

# True iff <path> is a symlink whose target is inside <src>.
adb_link_into() { [ -L "$1" ] && case "$(readlink "$1")" in "$2"/*) return 0 ;; esac; return 1; }

# Print one installed agent token per line — ONLY agents whose root-doc symlink points
# INTO <src>. An update must re-install exactly this set (never install.sh's bare default)
# and must never touch a root-doc symlink that points at an UNRELATED install (which
# install.sh would otherwise back up and replace with the baseline's).
# Usage: adb_installed_agents <src>
adb_installed_agents() {
  local src="$1"
  adb_link_into "$HOME/.claude/CLAUDE.md" "$src" && printf 'claude\n'
  adb_link_into "$HOME/.codex/AGENTS.md"  "$src" && printf 'codex\n'
  adb_link_into "$HOME/.gemini/GEMINI.md" "$src" && printf 'gemini\n'
  return 0
}

# True when the Claude Stop-hook gates are wired into settings.json. Used to preserve a
# prior `--no-hooks` choice across a self-heal (re-install would otherwise re-add them).
adb_hooks_wired() { grep -q 'precommit-gate\.sh' "$HOME/.claude/settings.json" 2>/dev/null; }

# Scan the ACTUAL installed symlinks that point INTO <src>, across ONLY the namespaces where a
# rename can leave an orphan: each agent's skills/* and scripts/* trees (Claude, Codex, and
# Antigravity/Gemini — whose skills live under ~/.gemini/config/). Unlike the manifest (what
# SHOULD be linked), this reports what IS linked — so a renamed-away orphan (a link into <src>
# with no current manifest entry) is visible to the pruner.
#
# Agent ROOT-DOC links (CLAUDE.md / AGENTS.md / GEMINI.md) are DELIBERATELY excluded: they live
# at fixed paths that never get renamed away, `bin/baseline` resolves the install source from a
# (possibly dangling) root-doc link, and `adb_installed_agents` detects an installed agent by it.
# A dangling root doc is therefore a genuine breakage to SURFACE (adb_link's guard fails the
# self-heal loudly), never an orphan to silently prune — pruning one would erase the very link
# detection depends on. NOT recursive: a user link deeper under ~/.claude is never in scope. A
# glob that matches nothing stays literal and is filtered by `-L`, so no `nullglob` is needed.
# Usage: adb_scan_links <src>
adb_scan_links() {
  local src="$1" p
  for p in "$HOME"/.claude/skills/* "$HOME"/.claude/scripts/* \
           "$HOME"/.codex/skills/* "$HOME"/.codex/scripts/* \
           "$HOME"/.gemini/config/skills/* "$HOME"/.gemini/scripts/*; do
    adb_link_into "$p" "$src" && printf '%s\n' "$p"
  done
}

# Enumerate the destinations the install SHOULD have linked, straight from the shared manifest
# (adb_agent_manifest) — the SAME producer install.sh links from — for every agent installed
# FROM <src> (adb_installed_agents). One dest per line. Because create-set and verify-set share
# one producer they can't drift: a path added/moved to the manifest is both linked AND verified,
# and a missing intended link (not just a dangling one) is caught. Usage: adb_manifest_dests <src>
adb_manifest_dests() {
  local src="$1" agent
  while IFS= read -r agent; do
    [ -n "$agent" ] || continue
    # `cut -f2` (TAB default) takes the <dest> column of this agent's manifest lines.
    adb_agent_manifest "$agent" "$src" "$HOME" | cut -f2
  done <<EOF
$(adb_installed_agents "$src")
EOF
}

# Return 0 iff every intended (manifest) install destination is OUR symlink into <src> AND
# resolves. On failure, name each broken dest on stderr — loud by design (issue #36 safety /
# issue #35 path-move fail-loud): a moved-away source (dangling link), a never-created link, OR a
# destination occupied by something that is NOT our link into the source (a real file, or a
# symlink pointing elsewhere) is surfaced, never silently tolerated. The last case matters
# because adb_link's guard deliberately leaves a pre-existing destination untouched when a source
# is missing (#48) — checking mere existence (`-e`) would then wrongly report that stale dest
# healthy and skip re-linking once the source returns (PR #51 review). Verifying the MANIFEST
# (not a scan of whatever happens to be linked) keeps verify from drifting from install.
# Usage: adb_verify_links <src>
adb_verify_links() {
  local src="$1" p broken=0
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    # Healthy == our symlink into src (adb_link_into) AND it resolves (-e). Anything else — a
    # dangling link, a real file, or a link pointing outside src — is BROKEN.
    if ! adb_link_into "$p" "$src" || [ ! -e "$p" ]; then
      printf 'baseline: BROKEN link (not our symlink into %s, or unresolved): %s\n' "$src" "$p" >&2
      broken=1
    fi
  done <<EOF
$(adb_manifest_dests "$src")
EOF
  return "$broken"
}

# Prune orphaned install links: a symlink in an install namespace that points INTO <src> but no
# longer resolves — the leftover a rename/removal creates (install.sh only ever adds/relinks,
# never removes; #48). STRICTLY ownership-scoped and re-checked at the moment of removal (never
# trusting the enumeration): a link is removed ONLY when it is a symlink, does NOT resolve, and
# its target is lexically inside <src>. A resolving link, a real file, or a link pointing
# elsewhere is never touched. Best-effort (always returns 0) — the subsequent adb_verify_links
# is the real gate. Usage: adb_prune_orphans <src>
adb_prune_orphans() {
  local src="$1" p
  while IFS= read -r p; do
    [ -n "$p" ] || continue
    [ -e "$p" ] && continue          # still resolves → legitimately installed, keep
    # Re-check ownership (symlink + target inside src) at the moment of removal, not trusting the
    # enumeration — adb_link_into re-reads the link, so this is TOCTOU-safe against a delete.
    adb_link_into "$p" "$src" && { rm -f "$p"; echo "baseline: pruned orphaned link (source renamed/removed): $p"; }
  done <<EOF
$(adb_scan_links "$src")
EOF
  return 0
}

# Re-run the idempotent installer for the ALREADY-installed agent set, preserving the
# hook preference. Never widens the install (no bare-default claude, no surprise hooks).
adb_self_heal() {
  local a
  local -a args=()
  while IFS= read -r a; do
    [ -n "$a" ] || continue
    args+=(--agent "$a")
  done <<EOF
$(adb_installed_agents "$SRC")
EOF
  if [ "${#args[@]}" -eq 0 ]; then
    echo "baseline: no installed agents detected — nothing to self-heal." >&2
    return 1
  fi
  # Preserve a prior --no-hooks: only when Claude is installed FROM THIS src but its
  # gates aren't wired (a root doc pointing elsewhere is not ours to re-wire).
  if adb_link_into "$HOME/.claude/CLAUDE.md" "$SRC" && ! adb_hooks_wired; then
    args+=(--no-hooks)
  fi
  echo "baseline: self-healing installed links → ./install.sh ${args[*]}"
  ( cd "$SRC" && ./install.sh "${args[@]}" ) || {
    echo "baseline: install.sh exited non-zero — inspect its output above (path move? see issue #35)." >&2
    return 1
  }
  return 0
}

# --- state -------------------------------------------------------------------

# Classify the install-source clone. Echoes exactly one word, cheapest-safety-first:
#   not-a-repo | dirty | detached | not-default | current | behind | ahead | diverged | no-remote
# Requires a prior `git fetch` for behind/ahead/diverged accuracy. The default branch is
# passed in (the caller already resolved it) so it isn't computed twice.
# Usage: adb_clone_status <root> <default-branch>
adb_clone_status() {
  local root="$1" default="$2" cur
  git -C "$root" rev-parse --git-dir >/dev/null 2>&1 || { printf 'not-a-repo\n'; return 0; }
  if [ -n "$(git -C "$root" status --porcelain 2>/dev/null)" ]; then printf 'dirty\n'; return 0; fi
  cur="$(git -C "$root" symbolic-ref --quiet --short HEAD 2>/dev/null)" || { printf 'detached\n'; return 0; }
  [ "$cur" = "$default" ] || { printf 'not-default\n'; return 0; }
  adb_branch_sync_state "$root" "$default"
}

# --- argument parsing --------------------------------------------------------

ACTION=""
CHECK=0
while [ $# -gt 0 ]; do
  case "$1" in
    update)      ACTION=update; shift ;;
    --check)     CHECK=1; shift ;;
    -h|--help)   usage; exit 0 ;;
    *) echo "baseline: unknown argument '$1'" >&2; echo >&2; usage >&2; exit 2 ;;
  esac
done
if [ "$ACTION" != "update" ]; then
  echo "baseline: expected a subcommand ('update')" >&2; echo >&2; usage >&2; exit 2
fi

# --- resolve the install-source clone ----------------------------------------

if ! SRC="$(adb_install_source)"; then
  echo "baseline: no installed baseline detected — no ~/.<agent> root-doc symlink points into a clone." >&2
  echo "          Nothing to keep current. Run install.sh from your baseline clone first." >&2
  exit 3
fi

# Guard the two-clone split: only ever update the clone the install points into. If
# baseline was invoked from a DIFFERENT clone (e.g. a dev checkout), refuse loudly
# rather than silently updating the wrong tree. `-ef` compares by device+inode (following
# symlinks), so the same clone reached via two path spellings is correctly seen as one;
# only genuinely distinct directories refuse.
if ! [ "$SRC" -ef "$REPO" ]; then
  echo "baseline: the global install points at the clone" >&2
  echo "            $SRC" >&2
  echo "          but you invoked baseline from" >&2
  echo "            $REPO" >&2
  echo "          Run 'baseline update' from the install-source clone above — that is the" >&2
  echo "          clone whose git state feeds every project. (A dev clone is kept current" >&2
  echo "          by /implement-issue's preflight auto-sync instead.)" >&2
  exit 4
fi

DEFAULT="$(adb_default_branch "$SRC")"

# --- fetch + classify --------------------------------------------------------

if ! git -C "$SRC" fetch --quiet origin 2>/dev/null; then
  [ "$CHECK" -eq 1 ] && echo "fetch-failed"
  echo "baseline: 'git fetch' failed in $SRC (offline?) — cannot determine currency." >&2
  exit 30
fi

STATUS="$(adb_clone_status "$SRC" "$DEFAULT")"

# --- --check: report only, mutate nothing ------------------------------------

if [ "$CHECK" -eq 1 ]; then
  echo "$STATUS"
  case "$STATUS" in
    current)                                exit 0  ;;
    behind)                                 exit 10 ;;
    dirty|ahead|diverged|detached|not-default) exit 20 ;;
    *)                                      exit 30 ;;   # no-remote | not-a-repo
  esac
fi

# --- update ------------------------------------------------------------------

case "$STATUS" in
  current)
    echo "baseline: install-source already current ($SRC on $DEFAULT, up to date with origin)."
    # Prune renamed-away orphans first (a prior manual `git pull` may have left one), THEN verify
    # the manifest — so a leftover from a rename doesn't force a needless "broken" repair (#48).
    adb_prune_orphans "$SRC"
    if adb_verify_links "$SRC"; then
      echo "baseline: all installed links resolve — nothing to do."
      exit 0
    fi
    echo "baseline: an installed path is broken though up to date — repairing …"
    adb_self_heal && adb_verify_links "$SRC" || { echo "baseline: repair failed — see above." >&2; exit 1; }
    echo "baseline: repaired."
    exit 0
    ;;
  behind)
    echo "baseline: updating $SRC ($DEFAULT is behind origin) …"
    if ! git -C "$SRC" pull --ff-only --quiet origin "$DEFAULT"; then
      echo "baseline: 'git pull --ff-only' failed — resolve manually in $SRC (never force-pulled)." >&2
      exit 20
    fi
    # Prune renamed-away orphans only AFTER a successful pull (never mutate the install if the
    # pull failed), then re-run the idempotent installer. install.sh links each skill and script
    # as its OWN destination, so a pulled commit that ADDS a skill/script needs a new symlink even
    # though every pre-existing link still resolves — "links resolve" does NOT imply "all payloads
    # linked." The installer is idempotent (unchanged links are a no-op); prune removes the links
    # a rename left dangling that the installer would otherwise never clean up.
    echo "baseline: pulled to origin/$DEFAULT; pruning orphaned links + re-running the idempotent installer …"
    adb_prune_orphans "$SRC"
    if adb_self_heal && adb_verify_links "$SRC"; then
      echo "baseline: update complete."
      exit 0
    fi
    echo "baseline: self-heal left a broken link — this is loud on purpose (see issue #35)." >&2
    exit 1
    ;;
  dirty)
    echo "baseline: install-source tree is dirty — skipping (never auto-pulls over uncommitted work)." >&2
    echo "          Commit or stash in $SRC, then re-run 'baseline update'." >&2
    exit 20
    ;;
  ahead|diverged|detached|not-default)
    echo "baseline: install-source is '$STATUS' on inspection — needs attention, not auto-pulling." >&2
    echo "          $SRC" >&2
    echo "          Reconcile it manually (the install-source clone should sit clean on $DEFAULT)." >&2
    exit 20
    ;;
  *)
    echo "baseline: cannot determine currency (status '$STATUS') for $SRC." >&2
    echo "          Is 'origin/$DEFAULT' present? Check the remote and re-run." >&2
    exit 30
    ;;
esac
