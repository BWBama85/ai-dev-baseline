#!/usr/bin/env bash
# ai-dev-baseline — per-project initializer.
#
# Run ANYWHERE inside a project's repo (it resolves the git root itself). Sets up this
# project's agent role manifest and the runtime state gitignore, then prints the effective
# role map. The global install already makes the skills + gates available everywhere; this
# is the lightweight per-project layer (base/practices/00-index.md: project overrides global).
#
# Repo-shape tolerant (#23): it resolves the git root even when called from a subdirectory, and
# surfaces a non-tidy shape — a repo nested inside an untracked parent tree, an out-of-repo root
# doc referenced by relative path, a monorepo/layered layout — instead of silently operating on
# the wrong root. It only ever initializes the resolved git root.
#
# Usage: agent-init [--force]     (--force overwrites an existing agents.toml)

set -uo pipefail

# Locate the installed baseline repo (this script lives in <repo>/bin/agent-init;
# when symlinked onto PATH, resolve through the link).
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do self="$(readlink "$self")"; done
REPO="$(cd "$(dirname "$self")/.." && pwd)"
# Shared shell primitives (adb_toml_get) — the ONE home, sourced not copied.
# shellcheck source=/dev/null
. "$REPO/scripts/lib/common.sh"

FORCE=0
[ "${1:-}" = "--force" ] && FORCE=1

# Resolve the project root shape-tolerantly (#23) via the shared primitive — the ONE home for
# the resolution; read its facts via the shared adb_shape_val/adb_shape_all accessors. Here we
# only SURFACE what it finds, then initialize the resolved git root.
shape="$(adb_repo_shape "$PWD")"

# Surface any diagnostics first, so a warning (e.g. an unreadable start) is shown BEFORE — and
# gives the real reason for — a refusal below, rather than being stranded after the exit path.
adb_shape_all "$shape" warning | while IFS= read -r m; do
  echo "warning: $m" >&2
done

if [ "$(adb_shape_val "$shape" in_git)" != "1" ]; then
  echo "ERROR: not inside a git repo — agent-init is a per-project initializer for a git repo." >&2
  echo "  Run it anywhere inside your project's repo (it resolves the git root itself), or" >&2
  echo "  'git init' this directory first if it really is a standalone project." >&2
  exit 1
fi
ROOT="$(adb_shape_val "$shape" root)"

# Surface any non-tidy repo shape BEFORE writing anything, so the operator sees exactly what
# agent-init can and cannot manage. None of these are errors — but agent-init must never pretend
# a wider project is invisible, nor operate on the wrong root. It reports facts and asks the
# operator to confirm the boundary; it never claims to know the "real" project extent.
[ "$(adb_shape_val "$shape" cwd_is_root)" = "0" ] && \
  echo "note: working dir is below the git root — initializing at the git root: $ROOT"

nested="$(adb_shape_val "$shape" nested_in)"
[ -n "$nested" ] && \
  echo "note: this repo is NESTED inside another git repo at $nested — that outer repo is out of scope here; agent-init manages only $ROOT."

foreign_docs="$(adb_shape_all "$shape" foreign_doc)"
if [ -n "$foreign_docs" ]; then
  printf '%s\n' "$foreign_docs" | while IFS= read -r d; do
    echo "note: found a root doc OUTSIDE this repo at $d — referenced by relative path but invisible to git-aware tooling; agent-init won't read or manage it."
  done
  # An out-of-repo doc above a repo whose parent is in no git repo is evidence this repo sits
  # inside a larger, untracked tree. Report the fact and ask; don't assert the project's extent.
  [ "$(adb_shape_val "$shape" parent_in_git)" = "0" ] && \
    echo "note: the git root's parent is outside any git repo — this repo may sit inside a larger, untracked project tree. Confirm which root your work maps to; agent-init initializes only the git root."
fi

adb_shape_all "$shape" extra_doc | while IFS= read -r d; do
  echo "note: found another project root doc in-tree at $d — this looks like a monorepo/layered layout; agent-init initializes only the top-level git root ($ROOT)."
done

trunc="$(adb_shape_val "$shape" scan_truncated)"
[ -n "$trunc" ] && \
  echo "note: stopped scanning parent directories after $trunc levels — if your project root is higher up, run agent-init closer to it."

cd "$ROOT" || { echo "ERROR: cannot cd to repo root: $ROOT" >&2; exit 1; }

# 1. Role manifest
if [ -f agents.toml ] && [ "$FORCE" -eq 0 ]; then
  echo "agents.toml exists (use --force to overwrite)"
else
  cp "$REPO/templates/agents.toml" agents.toml
  echo "wrote agents.toml — edit [roles] to set who is primary / reviews / debugs"
fi

# 2. Ensure runtime state is gitignored (marker/blocked files live here)
if [ -f .gitignore ] && grep -q '^\.claude/state/' .gitignore 2>/dev/null; then
  :
else
  printf '\n# ai-dev-baseline runtime state\n.claude/state/\n' >> .gitignore
  echo "added .claude/state/ to .gitignore"
fi
mkdir -p .claude/state

# 3. Show the effective role map — the FULL repo → global default → built-in resolution, via the
#    runtime helper (scripts/lib/role-dispatch.sh is the single source for the order, #15).
echo ""
echo "Effective roles for this repo:"
RD="$REPO/scripts/lib/role-dispatch.sh"
show_role() {
  local key="$1" v rc
  # `resolve` prints the token(s) (a `review` list is joined with commas); empty output with a
  # 0 status is a legitimate skip; a nonzero status is a manifest error (whose message it already
  # printed to stderr above).
  v="$(bash "$RD" resolve "$key")"; rc=$?
  if [ "$rc" -ne 0 ]; then
    printf '  %-13s %s\n' "$key" "(invalid — see the error above)"
  elif [ -z "$v" ]; then
    printf '  %-13s %s\n' "$key" "(unassigned — skipped)"
  else
    printf '  %-13s %s\n' "$key" "$(printf '%s' "$v" | paste -sd, -)"
  fi
}
show_role primary
show_role gap_analysis
show_role review
show_role debug
show_role issue_author
show_role release
echo ""
# `debug`, `issue_author`, and `release` resolve correctly but no shipped workflow consumes them
# yet — printing them without that caveat reads as "the baseline will do this for you." `release`
# especially: the baseline ships no /release skill on purpose (#3), so the token names WHO would
# cut a release in a project-owned skill you write.
echo "Note: only \`gap_analysis\` and \`review\` are consumed by a shipped workflow"
echo "      (/implement-issue). \`debug\`, \`issue_author\`, and \`release\` resolve for your"
echo "      own skills to honor — notably \`release\`: the baseline ships no /release skill."
echo ""
echo "Done. See docs/roles-and-agents.md for how roles resolve and delegate."
